# ============================================================
# PHP E-Commerce Website — Environment Configuration
# Copy this file to .env and update the values
# ============================================================

# Database
DB_HOST=localhost
DB_NAME=ecommerce_db
DB_USER=root
DB_PASS=

# App
APP_NAME="ShopEasy"
APP_URL=http://localhost/php-ecommerce-website
APP_ENV=development

# Timezone
APP_TIMEZONE=Asia/Kolkata
