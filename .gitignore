# ============================================================
# PHP E-Commerce Website — .gitignore
# ============================================================

# Environment file (contains DB credentials)
.env

# Uploaded product images (user-generated content)
uploads/products/*
!uploads/products/.gitkeep

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Composer (if added later)
/vendor/
composer.lock

# Node (if added later)
/node_modules/
package-lock.json

# Logs
*.log
error_log

# Temporary files
*.tmp
*.bak
*.cache
